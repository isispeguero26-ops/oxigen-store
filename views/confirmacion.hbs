<section class="factura my-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="factura-box p-5">

                    <!-- encabezado -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2>🌿 Oxigen</h2>
                            <p class="text-muted mb-0">Belleza que te hace brillar ✦</p>
                        </div>
                        <div class="text-end">
                            <h4>FACTURA</h4>
                            <p class="text-muted mb-0">N° {{ordenId}}</p>
                            <p class="text-muted mb-0">{{fecha}}</p>
                        </div>
                    </div>

                    <hr>

                    <!-- datos del cliente -->
                    <div class="mb-4">
                        <h6 class="text-muted">CLIENTE</h6>
                        <p class="mb-0"><strong>{{usuario.nombre}}</strong></p>
                        <p class="mb-0">{{usuario.email}}</p>
                    </div>

                    <hr>

                    <!-- productos -->
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each carrito}}
                            <tr>
                                <td>{{nombre}}</td>
                                <td class="text-center">{{cantidad}}</td>
                                <td class="text-end">${{precio}}</td>
                                <td class="text-end">${{subtotal}}</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>

                    <hr>

                    <!-- total -->
                    <div class="d-flex justify-content-end mb-4">
                        <div class="text-end">
                            <h5>Total: <strong>${{total}}</strong></h5>
                        </div>
                    </div>

                    <!-- mensaje -->
                    <div class="text-center py-3">
                        <p style="font-size: 2rem;">🎉</p>
                        <h5>¡Gracias por tu compra!</h5>
                        <p class="text-muted">Tu pedido ha sido procesado exitosamente.</p>
                    </div>

                    <div class="d-flex gap-2 justify-content-center">
                        <a href="/" class="btn btn-dark">Seguir comprando</a>
                        <button onclick="window.print()" class="btn btn-outline-dark">🖨️ Imprimir factura</button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>