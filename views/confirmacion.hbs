<section class="confirmacion my-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="confirmacion-box p-5">
                    <div style="font-size: 5rem;">🎉</div>
                    <h2 class="mt-3">¡Gracias por tu compra!</h2>
                    <p class="text-muted">Tu pedido ha sido recibido exitosamente.</p>
                    <hr>
                    <h5>Resumen de tu pedido:</h5>
                    <ul class="list-unstyled mt-3">
                        {{#each carrito}}
                        <li class="d-flex justify-content-between mb-2">
                            <span>{{nombre}} x{{cantidad}}</span>
                            <strong>${{subtotal}}</strong>
                        </li>
                        {{/each}}
                    </ul>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <h5>Total pagado:</h5>
                        <h5>${{total}}</h5>
                    </div>
                    <a href="/" class="btn btn-dark mt-4 w-100">Seguir comprando</a>
                </div>
            </div>
        </div>
    </div>
</section>