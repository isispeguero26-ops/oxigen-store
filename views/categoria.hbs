<section class="mas-vendidos my-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>{{categoriaActual}} ✦</h2>
            <a href="/" class="btn btn-outline-dark">← Volver al inicio</a>
        </div>
        <div class="row">
            {{#each productos}}
            <div class="col-md-3 col-6 mb-4">
                <div class="card producto-card h-100">
                    <img src="{{imagen_url}}" class="card-img-top" alt="{{nombre}}">
                    <div class="card-body">
                        <h6 class="card-title">{{nombre}}</h6>
                        <div class="estrellas">⭐ {{estrellas}}</div>
                        <p class="precio">${{precio}}</p>
                        <form action="/carrito/agregar" method="POST">
                            <input type="hidden" name="id" value="{{id}}">
                            <input type="hidden" name="nombre" value="{{nombre}}">
                            <input type="hidden" name="precio" value="{{precio}}">
                            <input type="hidden" name="imagen_url" value="{{imagen_url}}">
                            <button type="submit" class="btn btn-dark btn-sm w-100">🛒</button>
                        </form>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>